# PostgreSQL local development
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/flowai
SPRING_DATASOURCE_USERNAME=flowai
SPRING_DATASOURCE_PASSWORD=flowai_dev_password

# JWT secrets and token TTLs
# Use at least 32 bytes for HS256.
JWT_SECRET=replace-this-with-a-local-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# AI provider
# Required while the OpenAI Spring AI starter is enabled.
OPENAI_API_KEY=replace-with-your-openai-api-key
